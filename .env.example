FAISS_META_PATH=/data/faiss/meta.json
PROJECT_CLONE_PATH=/data/project_clone
UPLOADS_PATH=/data/uploads
GITHUB_TOKEN=ghp_xxx
REPO_NAME=your-org/quiz-frontend
